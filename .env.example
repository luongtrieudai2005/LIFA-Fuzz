# =============================================================================
# LIFA-Fuzz Environment Variables
# =============================================================================
# Copy this file to .env and fill in your API keys.
#   cp .env.example .env
#
# Only set the keys for the provider you are using.
# For Ollama (local), no API key is needed.
#
# The active provider is configured in config.yaml under slow_loop.llm_agent.

# =============================================================================
# OpenAI
# =============================================================================
OPENAI_API_KEY=sk-...

# =============================================================================
# Anthropic (Claude)
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-...

# =============================================================================
# ZhipuAI (via OpenAI-compatible endpoint)
# =============================================================================
# Set api_key_env to "ZHIPUAI_API_KEY" in config.yaml.
# Set api_base to "https://api.z.ai/api/coding/paas/v4" in config.yaml.
# Set provider to "openai" and model to "glm-5-turbo" in config.yaml.
ZHIPUAI_API_KEY=

# =============================================================================
# Ollama (local, no key needed)
# =============================================================================
# Uncomment if using a remote Ollama instance:
# OLLAMA_API_BASE=http://localhost:11434
